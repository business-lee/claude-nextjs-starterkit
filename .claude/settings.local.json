{
  "permissions": {
    "allow": [
      "WebSearch",
      "Bash",
      "WebFetch",
      "mcp__playwright__*",
      "mcp__sequential-thinking__*"
    ]
  },
  "enabledMcpjsonServers": [
    "playwright",
    "sequential-thinking"
  ],
  "enableAllProjectMcpServers": true,
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/slack-notify.sh permission"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/slack-notify.sh complete"
          }
        ]
      }
    ]
  }
}
